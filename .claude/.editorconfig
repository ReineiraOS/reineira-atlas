root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown -- preserve intentional trailing spaces (line breaks) but trim elsewhere
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

# JSON (settings.local.json etc.)
[*.json]
indent_style = space
indent_size = 2
